{
  "name": "databricks-agent-token-budgets",
  "description": "Enforces Databricks AI Gateway token budgets in Claude Code. Checks spending on session start and blocks prompts when a user exceeds their budget.",
  "version": "1.0.0",
  "author": {
    "name": "IceRhymers"
  },
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-budget.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-budget.sh --enforce",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
